{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"projects": {
		"levita-angular-example": {
			"root": "",
			"sourceRoot": "src",
			"projectType": "application",
			"prefix": "app",
			"architect": {
				"build": {
					"builder": "@angular-devkit/build-angular:browser",
					"options": {
						"outputPath": "dist",
						"index": "src/index.html",
						"main": "src/main.ts",
						"tsConfig": "tsconfig.app.json",
						"aot": false,
						"buildOptimizer": false,
						"styles": ["node_modules/levita-js/dist/style.css"]
					},
					"configurations": {
						"development": {
							"optimization": false,
							"sourceMap": true,
							"vendorChunk": true
						},
						"production": {
							"optimization": true,
							"sourceMap": false
						}
					},
					"defaultConfiguration": "development"
				},
				"serve": {
					"builder": "@angular-devkit/build-angular:dev-server",
					"configurations": {
						"development": {
							"buildTarget": "levita-angular-example:build:development"
						},
						"production": {
							"buildTarget": "levita-angular-example:build:production"
						}
					},
					"defaultConfiguration": "development"
				}
			}
		}
	}
}
